configfile: "config/config.yaml"


include: "rules/common.smk"
include: "rules/simulation.smk"
include: "rules/prediction.smk"
include: "rules/evaluation.smk"


rule all_simulations:
    input:
        collect_simulation_results("results/plots/fragments/simulation/{seq}/{n_fragments}"),


rule all_predictions:
    input:
        collect_simulation_results(
            "results/lionelmssq/simulation/{seq}/{n_fragments}.fasta",
            "results/plots/lionelmssq_prediction/simulation/{seq}/{n_fragments}.html",
        ),


rule all:
    input:
        rules.all_simulations.input,
        rules.all_predictions.input,
    default_target: True
