        "results/plots/evaluation/custom_simulation.bar.html",


rule all_random_simulation:
    input:
        "results/plots/evaluation/random_simulation.bar.html",


rule all_experiments:
    input:
        "results/plots/evaluation/experiment.bar.html",


rule all_plots:
    input:
        collect_experiments(
            "results/plots/lionelmssq_prediction/experiment/{seq}/{n_fragments}.html"
        ),
        # collect_simulations(
        #     "results/plots/lionelmssq_prediction/simulation/{seq}/{n_fragments}.html"
        # ),


rule all_comparisons:
    input:
        collect("results/plots/comparison_study/{parameter}.bar.html",
            parameter=lookup(dpath="comparison/studies", within=config)
        ),


rule all:
    input:
        # rules.all_custom_simulation.input,
