configfile: "config/config.yaml"


include: "rules/common.smk"
include: "rules/simulation.smk"
include: "rules/prediction.smk"
include: "rules/evaluation.smk"


rule all_simulations:
    input:
        collect_simulations(
            "results/lionelmssq/simulation/{seq}/{n_fragments}.fasta",
            "results/lionelmssq/simulation/{seq}/{n_fragments}.tsv",
            "results/plots/simulated_fragments/{seq}/{" "n_fragments}",
            "results/plots/lionelmssq_prediction/simulation/{seq}/{n_fragments}.html",
        ),


rule all_experiments:
    input:
        collect_experiments(
            "results/lionelmssq/experiment/{seq}/{n_fragments}.fasta",
            "results/lionelmssq/experiment/{seq}/{n_fragments}.tsv",
            "results/plots/lionelmssq_prediction/experiment/{seq}/{n_fragments}.html",
        ),


rule all:
    input:
        rules.all_simulations.input,
        rules.all_experiments.input,
    default_target: True
