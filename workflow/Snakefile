include: "rules/common.smk"
include: "rules/simulation.smk"
include: "rules/prediction.smk"
include: "rules/evaluation.smk"

report: "report/general.rst"

rule all_custom_simulation:
    input:
        "results/plots/evaluation/custom_simulation.bar.html",


rule all_random_simulation:
    input:
        "results/plots/evaluation/random_simulation.bar.html",


rule all_experiments:
    input:
        "results/plots/evaluation/experiment.bar.html",


rule all_plots:
    input:
        collect_experiments("results/plots/spectra/experiment/{seq}/{n_fragments}.html"),
        collect_experiments(
            "results/plots/prediction/experiment/{seq}/{n_fragments}.html"
        ),
        collect_custom_simulations(
            "results/plots/prediction/simulation/{seq}/{n_fragments}.html"
        ),


rule all_comparisons:
    input:
        collect(
            "results/plots/comparison_study/{parameter}.bar.html",
            parameter=lookup(dpath="comparison/studies", within=config),
        ),


rule all_optimizations:
    input:
        collect(
            "results/plots/optimization/{parameter}.bar.html",
            parameter=lookup(dpath="optimization", within=config),
        ),


rule all:
    input:
        rules.all_custom_simulation.input,
        # rules.all_random_simulation.input,
        rules.all_experiments.input,
        rules.all_plots.input,
        # rules.all_comparisons.input,
        # rules.all_optimizations.input,
    default_target: True
