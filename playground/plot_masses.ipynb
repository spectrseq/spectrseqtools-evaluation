    "import pandas as pd\n",
    "import altair as alt\n",
    "\n",
    "masses = pd.read_csv(\"../masses_all.tsv\", sep=\"\\t\")\n",
    "\n",
    "alt.Chart(masses).mark_bar(tooltip=True).encode(\n",
    "    alt.X(\"nucleoside\", sort=\"y\"),\n",
    "    alt.Y(\"monoisotopic_mass\")\n",
    ").interactive()"
   ]
